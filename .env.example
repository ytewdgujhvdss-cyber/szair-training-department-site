# 复制为 .env 后填写。不要把 .env 发给别人，也不要放到公开仓库。

# 网站服务端口
PORT=3000

# 方案 A：接 Dify 知识库聊天应用
# DIFY_API_KEY=app-xxxxxxxx
# DIFY_API_URL=https://api.dify.ai/v1/chat-messages
# 可选：当 Dify 检索结果没有返回文档 URL 时，点击来源跳转的 Dify 知识库/应用页面地址
# DIFY_KB_URL=https://cloud.dify.ai/app/xxxxxx 或 https://udify.app/xxxxxx

# 方案 B：接你们自己的知识库问答接口
# KNOWLEDGE_API_URL=https://example.com/api/ask
# KNOWLEDGE_API_KEY=xxxxxxxx

# 方案 C：接 ima 知识库（推荐，直接复用已有知识库）
# 1. 访问 https://ima.qq.com/agent-interface，申请 ClientId 和 ApiKey
# 2. 用下面接口列出 openapi 可访问的知识库，复制你要用的 id 填到 IMA_KNOWLEDGE_BASE_ID
#    curl -X POST https://ima.qq.com/openapi/wiki/v1/get_addable_knowledge_base_list \
#      -H "ima-openapi-clientid: your_client_id" \
#      -H "ima-openapi-apikey: your_api_key" \
#      -H "Content-Type: application/json" \
#      -d '{"cursor":"","limit":20}'
# 3. 注意：ima 客户端里看到的知识库 ID 与 openapi 返回的 ID 可能不同，必须以 get_addable_knowledge_base_list 返回的为准
# IMA_CLIENT_ID=your_client_id
# IMA_API_KEY=your_api_key
# IMA_KNOWLEDGE_BASE_ID=your_kb_id_from_openapi
# IMA_BASE_URL=https://ima.qq.com/openapi/wiki/v1

# 方案 D：钉钉 AI 助理 / 企业应用凭证
# 这组变量先作为凭证存放位；具体调用还需要确认钉钉 AI 助理的问答 API 或 CLI 命令。
# DINGTALK_ASSISTANT_ID=xxxxxxxx
# DINGTALK_CLIENT_ID=dingxxxxxxxx
# DINGTALK_CLIENT_SECRET=xxxxxxxx
# 小蜜智能问答 AskRobot。默认把 DINGTALK_ASSISTANT_ID 当作 robotAppKey 使用；
# 如果 API Explorer 中显示了单独的 robotAppKey，就单独填写 DINGTALK_ROBOT_APP_KEY。
# DINGTALK_ROBOT_APP_KEY=xxxxxxxx
# DINGTALK_SMART_QA_BASE_URL=https://api.dingtalk.com
# DINGTALK_SMART_QA_PATH=/v1.0/dingmi/robots/ask

# 可选：启用 LLM 总结（让回答更像自然语言，而非罗列标题）
# 支持 OpenAI 兼容接口，例如 DeepSeek、OpenAI、腾讯混元、Azure OpenAI 等
# LLM_API_KEY=your_llm_api_key
# LLM_API_URL=https://api.deepseek.com/v1/chat/completions
# LLM_MODEL=deepseek-chat
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx
# DINGTALK_SECRET=SECxxxxxxxx
